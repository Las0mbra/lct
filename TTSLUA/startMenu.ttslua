function refreshMat()
    mat = getObjectFromGUID(mat_GUID)
end

function normalizeMatTextureIndex(index)
    if index > #matTextures then
        return 1
    end
    if index < 1 then
        return #matTextures
    end
    return index
end

function applyMatTexture(rewriteMenu)
    matTextureSelected = normalizeMatTextureIndex(matTextureSelected)
    local selected = matTextures[matTextureSelected]
    local mapMat = getObjectFromGUID(mapMat_GUID)
    if not mapMat or not selected then return end

    local customInfo = mapMat.getCustomObject()
    if customInfo.image ~= selected.url then
        customInfo.image = selected.url
        mapMat.setCustomObject(customInfo)
        mapMat.reload()
    end

    if rewriteMenu then
        Wait.frames(function() writeMenus() end, 2)
    end
end

function setMatTexture(index)
    matTextureSelected = normalizeMatTextureIndex(index)
    applyMatTexture(true)
end

function setMatTexture1() setMatTexture(1) end
function setMatTexture2() setMatTexture(2) end
function setMatTexture3() setMatTexture(3) end
function setMatTexture4() setMatTexture(4) end

function writeSizeMenu()
    self.clearButtons()
    if sizeConfirmed then
        return
    end
    createButtonWithBorder(startBtnDisabled)
    self.createButton(sizeMenuBtn)
    sizeBtn.label=sizeData[mapSizeSelected].name
    self.createButton(sizeBtn)
    self.createButton(sizeUpBtn)
    self.createButton(sizeDownBtn)
    createButtonWithBorder(confirmBtn)
    createButtonWithBorder(confirmBtn4)
    mat.setScale(sizeData[mapSizeSelected].scale)
    mat.setPosition(positionValue)
end

function sizeUp()
    sizeUpDown(1)
end

function sizeDown()
    sizeUpDown(-1)
end

function sizeUpDown(increment)
    mapSizeSelected=mapSizeSelected+increment
    if mapSizeSelected > #sizeData then
        mapSizeSelected=1
    end
    if mapSizeSelected < 1 then
        mapSizeSelected=#sizeData
    end
    updateDeployObjectivesSelection()
    writeMenus()
end






function confirmForSingles()
    singlesMode = "singles"
    deployMode = "edition11"
    legacyPrimaryDeckEnabled = false
    loadGameWithoutMapContainers()
end

function confirmStandardGame()
    singlesMode = nil
    deployMode = "edition11"
    legacyPrimaryDeckEnabled = false
    loadGameWithoutMapContainers()
end

function loadGameWithoutMapContainers()
    destroyLegacyPrimaryDeck()
    placeStartupMapCards()
    placeForceDispositionToken()
    confirmSizeMat()
end

legacyPrimaryDeck_GUID = "d26e9c"
legacyPrimaryDeckPosition = {85.25, 0.95, -7.65}
legacyPrimaryDeckHiddenPosition = {89.238, -5.0, -6.352}

function setLegacyPrimaryDeckVisibility(visible)
    local deck = getObjectFromGUID(legacyPrimaryDeck_GUID)
    if not deck then
        return
    end

    if visible then
        deck.setLock(false)
        deck.setPosition(legacyPrimaryDeckPosition)
        deck.setRotation({0, 270, 180})
        deck.tooltip = true
        deck.interactable = true
    else
        deck.setPosition(legacyPrimaryDeckHiddenPosition)
        deck.setLock(true)
        deck.tooltip = false
        deck.interactable = false
    end
end

function showLegacyPrimaryDeck()
    setLegacyPrimaryDeckVisibility(true)
end

function destroyLegacyPrimaryDeck()
    destroyObjectByGUID(legacyPrimaryDeck_GUID)
end

